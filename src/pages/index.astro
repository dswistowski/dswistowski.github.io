---
import Layout from "../layouts/Layout.astro";
import yaml from "../../config.yaml";
import type { Asset, Config, Technology } from "../config";
import kaeiog from "../assets/kaeiog.pdf";
import GithubIcon from "../components/GithubIcon.astro";
import LinkedInIcon from "../components/LinkedInIcon.astro";
import PDFIcon from "../components/PDFIcon.astro";
import IconLink from "../components/IconLink.astro";
import cvPdf from "../../latex/cv.pdf";

const assets: Partial<Record<Asset, string>> = {
  kaeiog,
};

const config = yaml as Config;

const technologyLabels: Record<keyof Technology, string> = {
  languages: "Languages",
  backend: "Backend",
  data_storage: "Data & Storage",
  cloud_infra: "Cloud & Infrastructure",
  workflow_data_processing: "Workflow & Data Processing",
  other: "Other",
};

const technologyEntries = Object.entries(config.technology ?? {}).filter(
  ([, value]) => Array.isArray(value) && value.length > 0,
) as [keyof Technology, string[]][];

const contactLinks = [
  {
    label: config.email,
    href: `mailto:${config.email}`,
  },
  {
    label: config.phone,
    href: `tel:${config.phone}`,
  },
  {
    label: "LinkedIn",
    href: config.linkedin,
  },
  {
    label: "GitHub",
    href: config.github,
  },
];
---

<Layout title={`${config.name} CV`}>
  <main class="min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl rounded-[2rem] border border-stone-200 bg-white shadow-[0_24px_80px_rgba(15,23,42,0.08)]">
      <header class="border-b border-stone-200 px-6 py-8 sm:px-10 lg:px-12">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-slate-500">
              Curriculum Vitae
            </p>
            <h1 class="mt-3 font-heading text-4xl font-bold text-slate-950 sm:text-5xl">
              {config.name}
            </h1>
            <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm text-slate-600">
              {
                contactLinks.map((item) => (
                  <a href={item.href} class="hover:text-slate-900">
                    {item.label}
                  </a>
                ))
              }
            </div>
          </div>

          <div class="flex items-center gap-2 self-start">
            <IconLink href={config.github}>
              <GithubIcon />
            </IconLink>
            <IconLink href={config.linkedin}>
              <LinkedInIcon />
            </IconLink>
            <IconLink href={cvPdf}>
              <PDFIcon />
            </IconLink>
          </div>
        </div>

        <div class="mt-6 grid gap-3">
          {
            config.about_me.map((paragraph) => (
              <p class="max-w-4xl text-base leading-7 text-slate-700 sm:text-lg">
                {paragraph}
              </p>
            ))
          }
        </div>
      </header>

      <div class="grid gap-10 px-6 py-8 sm:px-10 lg:grid-cols-[minmax(0,1fr)_18rem] lg:px-12">
        <div class="space-y-10">
          <section>
            <h2>Professional Experience</h2>
            <div class="mt-4 space-y-8">
              {
                config.work.map((work) => (
                  <article class="border-l-2 border-stone-200 pl-5">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
                      <div>
                        <h3 class="text-xl font-semibold text-slate-950">
                          {work.title}
                        </h3>
                        <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">
                          {work.where} • {work.city}
                        </p>
                      </div>
                      <p class="text-sm font-semibold text-slate-500">
                        {work.date}
                      </p>
                    </div>

                    <ul class="mt-4 space-y-2 text-base leading-7 text-slate-700">
                      {
                        work.description.map((item) => (
                          <li class="flex gap-3">
                            <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-slate-400" />
                            <span>{item}</span>
                          </li>
                        ))
                      }
                    </ul>

                    <div class="mt-4 flex flex-wrap gap-2">
                      {
                        work.stack.map((item) => (
                          <span class="rounded-full border border-stone-300 bg-stone-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-600">
                            {item}
                          </span>
                        ))
                      }
                    </div>
                  </article>
                ))
              }
            </div>
          </section>

          {config.education && config.education.length > 0 && (
            <section>
              <h2>Education</h2>
              <div class="mt-4 space-y-5">
                {
                  config.education.map((item) => (
                    <article class="rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4">
                      <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                          <h3 class="text-lg font-semibold text-slate-950">
                            {item.what}
                          </h3>
                          <p class="text-sm text-slate-600">
                            {item.place}, {item.city}
                          </p>
                        </div>
                        <p class="text-sm font-medium text-slate-500">
                          {item.date}
                        </p>
                      </div>
                      {item.thesis && (
                        <p class="mt-3 text-sm leading-6 text-slate-700">
                          <span class="font-semibold text-slate-900">Thesis:</span>{" "}
                          {item.thesis}
                        </p>
                      )}
                    </article>
                  ))
                }
              </div>
            </section>
          )}

          {config.publications && config.publications.length > 0 && (
            <section>
              <h2>Publications</h2>
              <div class="mt-4 space-y-4">
                {
                  config.publications.map((publication) => {
                    const assetHref = publication.asset
                      ? assets[publication.asset]
                      : undefined;

                    return (
                      <article class="rounded-2xl border border-stone-200 px-5 py-4">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
                          <div>
                            <h3 class="text-lg font-semibold text-slate-950">
                              {assetHref ? (
                                <a href={assetHref}>{publication.title}</a>
                              ) : (
                                publication.title
                              )}
                            </h3>
                            <p class="text-sm uppercase tracking-[0.16em] text-slate-500">
                              {publication.journal}
                            </p>
                          </div>
                          <p class="text-sm font-medium text-slate-500">
                            {publication.date}
                          </p>
                        </div>
                        {publication.abstract && (
                          <p class="mt-3 text-sm leading-6 text-slate-700">
                            {publication.abstract}
                          </p>
                        )}
                      </article>
                    );
                  })
                }
              </div>
            </section>
          )}
        </div>

        <aside class="space-y-8 lg:pl-2">
          {config.core_skills && config.core_skills.length > 0 && (
            <section class="rounded-2xl bg-slate-950 px-5 py-5 text-white">
              <h2 class="text-stone-300">Core Skills</h2>
              <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-100">
                {
                  config.core_skills.map((skill) => (
                    <li class="border-b border-white/10 pb-2 last:border-b-0 last:pb-0">
                      {skill}
                    </li>
                  ))
                }
              </ul>
            </section>
          )}

          {technologyEntries.length > 0 && (
            <section>
              <h2>Technology</h2>
              <div class="mt-4 space-y-4">
                {
                  technologyEntries.map(([key, items]) => (
                    <article class="rounded-2xl border border-stone-200 px-4 py-4">
                      <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-600">
                        {technologyLabels[key]}
                      </h3>
                      <p class="mt-2 text-sm leading-6 text-slate-700">
                        {items.join(" • ")}
                      </p>
                    </article>
                  ))
                }
              </div>
            </section>
          )}

          {config.talks && config.talks.length > 0 && (
            <section>
              <h2>Talks</h2>
              <div class="mt-4 space-y-3">
                {
                  config.talks.map((talk) => (
                    <article class="rounded-2xl border border-stone-200 px-4 py-4">
                      <p class="text-sm font-semibold text-slate-900">
                        {talk.title}
                      </p>
                      <p class="mt-1 text-sm text-slate-600">
                        {talk.where} • {talk.date}
                      </p>
                      <div class="mt-3 flex flex-wrap gap-3 text-sm">
                        {talk.presentation && (
                          <a href={talk.presentation}>Slides</a>
                        )}
                        {talk.url && <a href={talk.url}>Video</a>}
                      </div>
                    </article>
                  ))
                }
              </div>
            </section>
          )}

          {config.interests && config.interests.length > 0 && (
            <section>
              <h2>Interests</h2>
              <p class="mt-4 text-sm leading-6 text-slate-700">
                {config.interests.join(" • ")}
              </p>
            </section>
          )}
        </aside>
      </div>
    </div>
  </main>
</Layout>
