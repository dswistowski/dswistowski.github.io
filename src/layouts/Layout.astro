---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body class="font-body antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:wght@600;700&display=swap");

  :root {
    color-scheme: light;
  }

  body {
    @apply bg-stone-100 text-slate-900;
  }

  h2 {
    @apply uppercase tracking-[0.22em] font-semibold text-xs py-2;
  }

  a {
    @apply underline-offset-4 transition;
  }

  a:hover {
    @apply text-slate-700;
  }

  h1,
  h2,
  h3 {
    @apply text-slate-900 font-heading;
  }

  h1 {
    @apply text-4xl tracking-tight;
  }
</style>
